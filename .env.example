# ── Base de Datos ──
POSTGRES_USER=postgres
POSTGRES_PASSWORD=tu_contraseña_segura
POSTGRES_DB=apidevops
DATABASE_URL=postgresql+psycopg2://postgres:tu_contraseña@localhost:5432/apidevops?sslmode=require

# ── Monitoreo y Observabilidad (V2) ──

# Prometheus Metrics (siempre habilitado en /metrics)
# Acceso en: http://localhost:8000/metrics

# ── Entorno ──
ENV=development
