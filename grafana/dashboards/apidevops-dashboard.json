{
  "uid": "apidevops-observability",
  "title": "APIDevOps Observability",
  "tags": ["apidevops", "prometheus", "grafana"],
  "timezone": "browser",
  "schemaVersion": 38,
  "version": 1,
  "refresh": "5s",
  "time": {
    "from": "now-15m",
    "to": "now"
  },
  "panels": [
    {
      "type": "timeseries",
      "title": "Request Rate (req/s)",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(rate(apidevops_requests_total{endpoint=~\"^/api/v(1|2)(/.*)?$\"}[1m]))",
          "legendFormat": "requests/sec"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "reqps"
        },
        "overrides": []
      },
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom" }
      }
    },
    {
      "type": "timeseries",
      "title": "Error Rate (errors/s)",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(rate(apidevops_requests_errors_total{endpoint=~\"^/api/v(1|2)(/.*)?$\"}[5m]))",
          "legendFormat": "errors/sec"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "reqps"
        },
        "overrides": []
      },
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom" }
      }
    },
    {
      "type": "timeseries",
      "title": "P95 Latency (seconds)",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "targets": [
        {
          "refId": "A",
          "expr": "histogram_quantile(0.95, sum(rate(apidevops_request_duration_seconds_bucket{endpoint=~\"^/api/v(1|2)(/.*)?$\"}[5m])) by (le))",
          "legendFormat": "p95"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s"
        },
        "overrides": []
      },
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom" }
      }
    },
    {
      "type": "bargauge",
      "title": "Top Endpoints (requests)",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "targets": [
        {
          "refId": "A",
          "expr": "topk(5, sum by (endpoint) (apidevops_requests_total{endpoint=~\"^/api/v(1|2)(/.*)?$\"}))",
          "legendFormat": "{{endpoint}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short"
        },
        "overrides": []
      },
      "options": {
        "orientation": "horizontal",
        "displayMode": "gradient",
        "showUnfilled": true
      }
    },
    {
      "type": "stat",
      "title": "Total Requests",
      "gridPos": { "h": 6, "w": 6, "x": 0, "y": 16 },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(apidevops_requests_total{endpoint=~\"^/api/v(1|2)(/.*)?$\"})",
          "legendFormat": "total"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": { "mode": "value" }
        },
        "overrides": []
      },
      "options": {
        "colorMode": "value",
        "graphMode": "none",
        "justifyMode": "center"
      }
    },
    {
      "type": "stat",
      "title": "Total Errors",
      "gridPos": { "h": 6, "w": 6, "x": 6, "y": 16 },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(apidevops_requests_errors_total{endpoint=~\"^/api/v(1|2)(/.*)?$\"})",
          "legendFormat": "errors"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": { "mode": "value" }
        },
        "overrides": []
      },
      "options": {
        "colorMode": "value",
        "graphMode": "none",
        "justifyMode": "center"
      }
    },
    {
      "type": "stat",
      "title": "Health Check",
      "gridPos": { "h": 6, "w": 6, "x": 12, "y": 16 },
      "targets": [
        {
          "refId": "A",
          "expr": "up{job=\"apidevops\"}",
          "legendFormat": "up"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": 0 },
              { "color": "green", "value": 1 }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "center"
      }
    }
  ]
}
